[worldserver]

########################################
# Mod Reforging configuration
########################################
#
#    Reforging.Enable
#        Description: Enable Reforging module
#        Default:     0 - Disabled
#                     1 - Enabled
#

Reforging.Enable = 1

#
#    Reforging.ReforgeableStats
#        Description: Stats that can be reforged. These are usually secondary stats like spirit, hit rating, etc. These correspond
#                     to ItemModType enum in ItemTemplate.h. Choose a MAXIMUM of 15 stats.
#        Default:     6,13,14,31,32,36,37 (Spirit, Dodge Rating, Parry Rating, Hit Rating, Crit Rating, Haste Rating, Expertise Rating)
#

Reforging.ReforgeableStats = 6,13,14,31,32,36,37

#
#    Reforging.Percentage
#        Description: A number between 10 and 90 which calculates how much from the reforged stat goes into another stat.
#                     Example: if you reforge 130 Spirit and this percentage is 40, then the new stat will be 52 (40% of 130)
#        Default:     40 - 40% of reforged stat goes to another (that's what Blizzard used back when reforging was a thing)
#

Reforging.Percentage = 40

###################################################################################################
# Reforging Cost System (Per-Slot)
###################################################################################################
#
#    Reforging.Cost.Enable
#        Description: Enable cost for reforging items
#        Default:     0 - Disabled
#                     1 - Enabled
#

Reforging.Cost.Enable = 0

#
#    Reforging.Cost.Slot.XXX.Currency
#        Description: Currency type for reforging this specific equipment slot.
#                     0 = Gold (copper), any other value = Item entry ID used as token.
#        Default:     0 (Gold)
#
#    Reforging.Cost.Slot.XXX.Amount
#        Description: Cost amount. If currency is 0 (Gold), this is in copper (e.g. 500000 = 50g).
#                     If currency is an item entry, this is the number of tokens required.
#                     Set to 0 to make this slot free to reforge.
#        Default:     0 (no cost)
#
#    Available slots: Head, Neck, Shoulders, Shirt, Chest, Waist, Legs, Feet,
#                     Wrists, Hands, Finger1, Finger2, Trinket1, Trinket2,
#                     Back, MainHand, OffHand, Ranged, Tabard
#

Reforging.Cost.Slot.Head.Currency = 0
Reforging.Cost.Slot.Head.Amount = 0
Reforging.Cost.Slot.Neck.Currency = 0
Reforging.Cost.Slot.Neck.Amount = 0
Reforging.Cost.Slot.Shoulders.Currency = 0
Reforging.Cost.Slot.Shoulders.Amount = 0
Reforging.Cost.Slot.Shirt.Currency = 0
Reforging.Cost.Slot.Shirt.Amount = 0
Reforging.Cost.Slot.Chest.Currency = 0
Reforging.Cost.Slot.Chest.Amount = 0
Reforging.Cost.Slot.Waist.Currency = 0
Reforging.Cost.Slot.Waist.Amount = 0
Reforging.Cost.Slot.Legs.Currency = 0
Reforging.Cost.Slot.Legs.Amount = 0
Reforging.Cost.Slot.Feet.Currency = 0
Reforging.Cost.Slot.Feet.Amount = 0
Reforging.Cost.Slot.Wrists.Currency = 0
Reforging.Cost.Slot.Wrists.Amount = 0
Reforging.Cost.Slot.Hands.Currency = 0
Reforging.Cost.Slot.Hands.Amount = 0
Reforging.Cost.Slot.Finger1.Currency = 0
Reforging.Cost.Slot.Finger1.Amount = 0
Reforging.Cost.Slot.Finger2.Currency = 0
Reforging.Cost.Slot.Finger2.Amount = 0
Reforging.Cost.Slot.Trinket1.Currency = 0
Reforging.Cost.Slot.Trinket1.Amount = 0
Reforging.Cost.Slot.Trinket2.Currency = 0
Reforging.Cost.Slot.Trinket2.Amount = 0
Reforging.Cost.Slot.Back.Currency = 0
Reforging.Cost.Slot.Back.Amount = 0
Reforging.Cost.Slot.MainHand.Currency = 0
Reforging.Cost.Slot.MainHand.Amount = 0
Reforging.Cost.Slot.OffHand.Currency = 0
Reforging.Cost.Slot.OffHand.Amount = 0
Reforging.Cost.Slot.Ranged.Currency = 0
Reforging.Cost.Slot.Ranged.Amount = 0
Reforging.Cost.Slot.Tabard.Currency = 0
Reforging.Cost.Slot.Tabard.Amount = 0

